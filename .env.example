# n8n orchestrator (used by docker-compose.yml)
N8N_USER=
N8N_PASSWORD=

# SIS (Student Information System) credentials
SIS_USERNAME=
SIS_PASSWORD=

# Webhook auth (shared secret for n8n -> Cloud Run)
WEBHOOK_SECRET=

# GitHub data repo (used by Cloud Run /rebuild-index and scripts/)
GITHUB_TOKEN=
DATA_REPO=

# n8n MCP server (used by .mcp.json to give Claude Code read-write access
# to the n8n public REST API). Generate the key in n8n -> Settings -> API.
N8N_API_URL=https://n8n.davebrot.com/api/v1
N8N_API_KEY=